{
  "pluginAlias": "homebridge-luxtronik2",
  "pluginType": "platform",
  "singular": true,
  "header": "Platform plugin for one Luxtronik2 controller. Required for child-bridge and Homebridge 2.0 Matter support. Expose one or more temperature sensors.",
  "footerDisplay": "If this plugin is useful, please [star it on GitHub](https://github.com/cbrandlehner/homebridge-luxtronik2). Report problems on the [issue tracker](https://github.com/cbrandlehner/homebridge-luxtronik2/issues).",
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "name": {
        "title": "Platform Name",
        "description": "Label for this platform instance in Homebridge.",
        "type": "string",
        "required": true,
        "default": "Luxtronik2"
      },
      "IP": {
        "title": "Controller IP",
        "description": "IPv4 address of the Luxtronik2 heat pump controller.",
        "type": "string",
        "required": true,
        "default": "192.168.1.202",
        "format": "hostname"
      },
      "Port": {
        "title": "Controller Port",
        "description": "Luxtronik2 TCP port. Usually 8888.",
        "type": "integer",
        "default": 8888,
        "maximum": 65535,
        "required": true
      },
      "sensors": {
        "title": "Temperature Sensors",
        "description": "Each sensor becomes its own HomeKit temperature accessory.",
        "type": "array",
        "required": true,
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "title": "Sensor Name",
              "type": "string",
              "required": true,
              "default": "Luxtronik2 Temperature"
            },
            "channel": {
              "title": "Temperature Channel",
              "description": "Compacted channel index. Channel 5 is outdoor air (Temperatur_TA).",
              "type": "integer",
              "required": true,
              "oneOf": [
                { "title": "0 · Temperatur_TVL — Heating flow (supply)", "enum": [0] },
                { "title": "1 · Temperatur_TRL — Heating return", "enum": [1] },
                { "title": "2 · Sollwert_TRL_HZ — Heating return setpoint", "enum": [2] },
                { "title": "3 · Temperatur_TRL_ext — Buffer tank return", "enum": [3] },
                { "title": "4 · Temperatur_THG — Hot gas (compressor)", "enum": [4] },
                { "title": "5 · Temperatur_TA — Outdoor air", "enum": [5] },
                { "title": "6 · Mitteltemperatur — 24h avg outdoor", "enum": [6] },
                { "title": "7 · Temperatur_TBW — Domestic hot water (actual)", "enum": [7] },
                { "title": "8 · Einst_BWS_akt — Domestic hot water setpoint", "enum": [8] },
                { "title": "9 · Temperatur_TWE — Heat source inlet", "enum": [9] },
                { "title": "10 · Temperatur_TWA — Heat source outlet", "enum": [10] },
                { "title": "11 · Temperatur_TFB1 — Mixing circuit 1 flow", "enum": [11] },
                { "title": "12 · Sollwert_TVL_MK — Mixing circuit 1 setpoint", "enum": [12] },
                { "title": "13 · Temperatur_RFV — Room station 1", "enum": [13] },
                { "title": "14 · Temperatur_TFB2 — Mixing circuit 2 flow", "enum": [14] },
                { "title": "15 · Sollwert_TVL_MK2 — Mixing circuit 2 setpoint", "enum": [15] },
                { "title": "16 · Temperatur_TSK — Solar collector", "enum": [16] },
                { "title": "17 · Temperatur_TSS — Solar storage tank", "enum": [17] },
                { "title": "18 · Temperatur_TEE — External heat source", "enum": [18] }
              ]
            }
          }
        }
      }
    }
  }
}